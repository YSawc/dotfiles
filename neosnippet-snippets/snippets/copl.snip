snippet     by_P-Zero
options     head
    Z plus ${1} is ${2} by P_Zero {};

snippet     by_L_Trans
options     head
    ${1} plus ${2} is ${3} by P-Succ {
    $0
    };

snippet     by_T-Zero
options     head
    Z times ${1} is Z by T_Zero {};

snippet     by_T-Succ
options     head
    ${1} times ${2} is ${3} by T_Succ {
    $0
    };

snippet     by_L_Trans
options     head
    ${1} is less than ${2} by L_Trans {
    $0
    };
