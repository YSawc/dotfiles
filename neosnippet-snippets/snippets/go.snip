snippet     package_init
options     head
    package ${1:#:base_type}

    func $1() {
      $0
    }

snippet     iferr
alias       ife
options     head
    if err != nil {
      return `g:NeosnippetSnippets_Goiferr()`
    }
    ${2}

snippet     if_e_log
alias       ifel
options     head
    if err != nil {
      log.Fatal(err)
    }
