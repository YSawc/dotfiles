" スワップファイルを作成しない
set noswapfile

" start up NERDTree
autocmd vimenter * NERDTree

"左右のカーソル移動で行間移動可能にする。
set whichwrap=b,s,<,>,[,]


" vimを立ち上げたときに、自動的にvim-indent-guidesをオンにする vim-indent-guides
let g:indent_guides_enable_on_vim_startup = 1

" タブの代わりに空白を使う
set expandtab

" バックスペースでの削除をいつでも有効にする
set backspace=indent,eol,start

" mouseScroll on
set mouse=a
set ttymouse=xterm2
