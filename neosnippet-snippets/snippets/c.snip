snippet     ifndef
options     head
alias       #ifndef
abbr #ifndef ... #define ... #endif
    #ifndef $1
    #define ${1:#:SYMBOL}



    #endif${0}

snippet     strtoalpha
options     head
    static char *strtoalpha(char *s) {
      char *strArr = malloc(24);
      for (int i = 0; s[i]!='\0'; i++) {
        if (isalpha(s[i])) {
          strArr[i] = s[i];
        } else {
          break;
        }
      }
      return strArr;
    }
