snippet     package_init
options     head
    package ${1:#:base_type}

    func $1() {
      $0
    }

snippet     iferr
alias       ife
options     head
    if err != nil {
      return `g:NeosnippetSnippets_Goiferr()`
    }
    ${2}

snippet     if_e_log
alias       ifel
options     head
    if err != nil {
      log.Fatal(err)
    }

snippet     for_ipp
alias       fori
options     head
    for i := 0; i < ${1:#:obj}; i++ {
      $0
    }
